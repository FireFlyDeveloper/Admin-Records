# Database Configuration
DB_USER=your_db_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=admin_records

# Redis Configuration (optional - for caching/sessions)
# REDIS_URL=redis://localhost:6379

# Email Configuration (for notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# Monitoring (Grafana)
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# CORS (allowed frontend origin)
CORS_ORIGIN=https://your-domain.com

# API Security
API_KEY_SECRET=generate_random_string_here

# SSL/TLS (for production HTTPS)
# SSL_CERT_PATH=/etc/ssl/certs/your-cert.pem
# SSL_KEY_PATH=/etc/ssl/private/your-key.pem

# --- Development Overrides (remove for production) ---
# NODE_ENV=development