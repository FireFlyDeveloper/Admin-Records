# ── Runtime ──
NODE_ENV=development
PORT=3000
WS_PORT=3001

# ── Database ──
# Local Node.js dev:
DATABASE_URL=postgresql://casaos:<password>@localhost:5432/admin_records
# Docker Compose using PostgreSQL already running on the host:
# DATABASE_URL=postgresql://casaos:<password>@host.docker.internal:5432/admin_records

# ── Auth ──
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRY_SECONDS=3600
JWT_REFRESH_EXPIRY_SECONDS=604800

# ── CORS (comma-separated frontend URLs) ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com
FRONTEND_URL=http://localhost:5173,https://your-domain.com
APP_URL=http://localhost:3000

# ── File Storage ──
UPLOAD_DIR=./uploads
FILE_STORAGE_BACKEND=local
FILE_STORAGE_PATH=./storage

# ── Redis (optional) ──
# REDIS_URL=redis://localhost:6379

# ── Email (optional) ──
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your_email@gmail.com
# MAIL_PASS=your_app_specific_password
# MAIL_FROM=noreply@your-domain.com

# ── MQTT / IoT BLE Tracking ──
# MQTT_URL=mqtt://localhost:1883
# MQTT_BLE_TOPIC=ble/events
# BLE_CONFLICT_WINDOW_SECONDS=5
# BLE_MISSING_THRESHOLD_MINUTES=10
# BLE_DEVICE_OFFLINE_THRESHOLD_MINUTES=2
# BLE_HEARTBEAT_INTERVAL_SECONDS=30
# MISSING_JOB_INTERVAL_SECONDS=60

# ── ONLYOFFICE Document Server (optional) ──
# OFFICE_DOC_SERVER_URL=http://localhost:8080
# OFFICE_JWT_SECRET=office-secret-change-me

# ── Rate Limiting ──
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ──
# LOG_LEVEL=info
