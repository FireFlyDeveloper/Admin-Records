# ── Runtime ──
NODE_ENV=development
PORT=3000
WS_PORT=3001
LOG_LEVEL=debug

# ── Database (local dev: pg running on host or Docker) ──
DATABASE_URL=postgresql://admin:admin123@host.docker.internal:5432/admin_records

# ── Auth ──
JWT_SECRET=dev-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_EXPIRY_SECONDS=3600
JWT_REFRESH_EXPIRY_SECONDS=604800

# ── CORS (comma-separated frontend URLs) ──
ALLOWED_ORIGINS=https://adminrecords.xyz,http://localhost:3000,http://localhost:5173,https://api.adminrecords.xyz
FRONTEND_URL=https://adminrecords.xyz
APP_URL=https://api.adminrecords.xyz

# ── File Storage ──
UPLOAD_DIR=./uploads
FILE_STORAGE_BACKEND=local
FILE_STORAGE_PATH=./storage

# ── Redis (optional — sessions / caching) ──
REDIS_URL=redis://host.docker.internal:6379

# ── Email (SMTP) ──
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@inventory.local

# ── MQTT (IoT / BLE asset tracking) ──
MQTT_URL=mqtt://host.docker.internal:1883
MQTT_BLE_TOPIC=ble/events
MQTT_HEARTBEAT_TOPIC=device/heartbeat
BLE_CONFLICT_WINDOW_SECONDS=5
BLE_MISSING_THRESHOLD_MINUTES=10
BLE_DEVICE_OFFLINE_THRESHOLD_MINUTES=2
BLE_HEARTBEAT_INTERVAL_SECONDS=30
MISSING_JOB_INTERVAL_SECONDS=60

# ── ONLYOFFICE Document Server ──
OFFICE_DOC_SERVER_URL=https://documents.adminrecords.xyz
OFFICE_JWT_SECRET=office-secret-change-me

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
